# ================= Unity (unity_game/) =================
unity_game/Library/
unity_game/Temp/
unity_game/Logs/
unity_game/Builds/
unity_game/UserSettings/
unity_game/obj/
unity_game/.vscode/
unity_game/*.csproj
unity_game/*.sln
unity_game/*.slnf

# screenshots / local media dumps inside the Unity project (not used by the game)
unity_game/Assets/Screenshots/
unity_game/drive-download-*/
unity_game/drive-download-*.zip
unity_game/*.png
unity_game/*.jpg
unity_game/*.jpeg
unity_game/*.mp4
unity_game/*.wav
unity_game/*.fbx
unity_game/*.zip

# oversized archives (FallDudes.rar is 186MB — over GitHub's 100MB hard limit)
*.rar

# ================= Node (web/ + server/) =================
node_modules/
web/dist/
server/dist/
*.log

# env files (only .env.example templates are committed)
.env
.env.local
.env.*.local

# marketing/recording dumps — contains a 531MB .mp4, far over GitHub's 100MB hard limit,
# so an unguarded `git add -A` here would fail the push outright
Twitter Screens/

# ad-hoc Unity scene recovery dumps (~6MB each). The already-committed 0.unity / 0 (1).unity
# stay tracked — this only stops NEW dumps from leaking in.
unity_game/Assets/_Recovery/

# regenerated into Resources/ by the Performance Testing package on every player build
unity_game/Assets/Resources/PerformanceTestRun*.json

