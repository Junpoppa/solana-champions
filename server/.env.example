# Copy to .env and adjust. All optional (defaults shown).
PORT=8787
CAPACITY=20
# Minimum players to start when the fill countdown expires. Set to 1 for solo local testing.
MIN_TO_START=2
# How long a room waits (ms) for more players before starting (re-arms if under MIN_TO_START).
FILL_COUNTDOWN_MS=30000
# Lead time (ms) between broadcasting matchStart and the authoritative start moment.
START_DELAY_MS=3500
# After all-but-one players report, wait this long (ms) for the last straggler.
RESULT_GRACE_MS=8000
# Hard safety cap (ms) on a running match so a hung client can't stall a room forever.
MATCH_MAX_MS=180000
# In production set to your web origin (e.g. https://solchampions.example) to reject other origins.
# Leave empty in dev to allow any origin.
ALLOWED_ORIGIN=
